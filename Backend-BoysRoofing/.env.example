# Copia a .env y rellena. En Railway configura estas variables en el dashboard del servicio.

# Base de datos (Railway Postgres te da esta URL al crear la base)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# JWT para el login del admin
JWT_SECRET="un-secreto-muy-largo-y-aleatorio"

# Opcional: correo (Resend) para facturas
RESEND_API_KEY=""
FROM_EMAIL=""

# Opcional: detección de techo desde imagen satelital (usa el mismo token que el frontend)
MAPBOX_TOKEN="pk.xxx"
