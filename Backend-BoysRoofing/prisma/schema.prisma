generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quote {
  id               Int          @id @default(autoincrement())
  name             String
  email            String
  phone            String
  service          String
  message          String?
  address          String       // Dirección
  city             String       // Ciudad
  state            String       // Estado
  zip              String       // Código postal
  propertyLocation String       // Ubicación de la propiedad
  activo           Boolean      @default(true)      // Cotización activa / inactiva
  status           QuoteStatus  @default(PENDING)   // Estado de la cotización
  createdAt        DateTime     @default(now())

  // Relación 1:N con Review
  reviews          Review[]

  // Relación 1:1 con Invoice (una cotización tiene un invoice opcional)
  invoice          Invoice?
}

model Invoice {
  id               Int      @id @default(autoincrement())
  quoteId          Int      @unique
  quote            Quote    @relation(fields: [quoteId], references: [id])

  billTo           String
  phone            String
  address          String
  city             String
  state            String
  zip              String
  propertyLocation String

  invoiceNumber    String
  invoiceDate      DateTime

  description      String      // Texto grande del trabajo / materiales
  price            Float       // Precio principal
  subtotal         Float
  other            Float?      // Otros cargos (si aplica)
  total            Float       // Total final

  createdAt        DateTime    @default(now())
}

enum QuoteStatus {
  PENDING    // Recibida, pero sin atender
  IN_REVIEW  // El dueño ya la vio / en proceso
  SENT       // Cotización / invoice enviado al cliente
  CLOSED     // Cerrada (aceptada / rechazada)
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  quoteId   Int
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name      String
  email     String
  rating    Int
  message   String
  createdAt DateTime @default(now())
}

// --------------- NÓMINA ---------------

model Worker {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String?
  role            String?
  defaultDayRate  Float    @default(0)
  isActive        Boolean  @default(true)
  balance         Float    @default(0)   // saldo acumulado (positivo = yo le debo, negativo = me debe)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrollEntries  PayrollEntry[]
}

enum PayrollPeriodStatus {
  DRAFT
  PAID
  CLOSED
}

model PayrollPeriod {
  id          Int                 @id @default(autoincrement())
  startDate   DateTime
  endDate     DateTime
  label       String?
  status      PayrollPeriodStatus  @default(DRAFT)
  totalPaid   Float?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  entries     PayrollEntry[]
}

enum WorkerType {
  REGULAR
  OCCASIONAL
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model PayrollEntry {
  id             Int            @id @default(autoincrement())
  payrollPeriodId Int
  payrollPeriod  PayrollPeriod  @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  workerType     WorkerType
  workerId       Int?
  worker         Worker?        @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerName     String?        // para ocasionales o display

  fullDays       Int            @default(0)
  halfDays       Int            @default(0)
  dayRate        Float
  halfDayRate    Float
  bonuses        Float          @default(0)
  deductions     Float          @default(0)
  notes          String?

  total          Float          @default(0)
  prevBalance    Float          @default(0)
  amountPaid     Float          @default(0)
  balanceAfter   Float          @default(0)
  paymentStatus  PaymentStatus  @default(UNPAID)
  paidAt         DateTime?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workDays       WorkDay[]
}

enum WorkDayType {
  FULL
  HALF
  OFF
}

model WorkDay {
  id              Int         @id @default(autoincrement())
  payrollEntryId  Int
  payrollEntry    PayrollEntry @relation(fields: [payrollEntryId], references: [id], onDelete: Cascade)
  date            DateTime
  type            WorkDayType  @default(OFF)
  createdAt       DateTime    @default(now())
}

// --------------- RECIBOS DE PAGO ---------------

model PaymentReceipt {
  id             Int      @id @default(autoincrement())
  receiptNumber  String
  date           DateTime
  clientName     String
  clientEmail    String?
  amount         Float
  concept        String
  notes          String?
  createdAt      DateTime @default(now())
}

// --------------- IMÁGENES DEL SITIO (Cloudinary) ---------------

model SiteImage {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // ej: hero, home_about, logo
  url       String   // URL de Cloudinary (secure_url)
  updatedAt DateTime @updatedAt
}
